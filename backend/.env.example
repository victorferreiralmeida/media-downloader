# Origens permitidas (separadas por vírgula). GitHub Pages é aceito via regex.
CORS_ORIGINS=http://localhost:5500,https://seu-usuario.github.io

# Diretório temporário para downloads
TEMP_DIR=./temp

# Tempo máximo de vida de um job (segundos)
JOB_TTL_SECONDS=3600

# Duração máxima do vídeo em segundos (padrão: 2 horas)
MAX_DURATION_SECONDS=7200
